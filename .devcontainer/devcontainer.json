{
    "name": "ParSecNova-Rust-Dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "serayuzgur.crates"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/dist,target=/workspaces/ParSecNova/dist,type=bind"
    ],
    "remoteUser": "vscode"
}